<Window x:Class="PriceTrackerAlert.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚙ Settings" Width="500" Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1A1A2E"
        Icon="/Assets/icon.ico">

    <Window.Resources>

        <!-- ── Slim dark ScrollBar ── -->
        <Style x:Key="ScrollThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#3D3D5F" CornerRadius="3" Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4CAF50"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="#12121C" CornerRadius="3" Width="6">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="8"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar Grid.Column="1" x:Name="PART_VerticalScrollBar"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Dark ComboBox ── -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D3F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3D3D5F"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd" Background="#2D2D3F" BorderBrush="#3D3D5F"
                                    BorderThickness="1" CornerRadius="6"/>
                            <Grid Margin="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="28"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                  Margin="12,0,0,0" VerticalAlignment="Center"
                                                  IsHitTestVisible="False"/>
                                <ToggleButton Grid.ColumnSpan="2" Opacity="0"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                                <Path Grid.Column="1" Data="M0,0 L5,6 L10,0" Stroke="#78909C"
                                      StrokeThickness="1.5" HorizontalAlignment="Center"
                                      VerticalAlignment="Center" IsHitTestVisible="False"/>
                            </Grid>
                            <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Fade" Placement="Bottom">
                                <Border Background="#2D2D3F" BorderBrush="#3D3D5F" BorderThickness="1"
                                        CornerRadius="6" MinWidth="{TemplateBinding ActualWidth}">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="12" Opacity="0.4" ShadowDepth="4"/>
                                    </Border.Effect>
                                    <ScrollViewer>
                                        <ItemsPresenter Margin="0,4"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4CAF50"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}" CornerRadius="4" Margin="4,1">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#3D3D5F"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── TextBox ── -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D3F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderBrush" Value="#3D3D5F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#4CAF50"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── CheckBox ── -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#B0BEC5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Box" Width="18" Height="18" CornerRadius="4"
                                    Background="#2D2D3F" BorderBrush="#3D3D5F" BorderThickness="1.5"
                                    VerticalAlignment="Center">
                                <Path x:Name="Check" Data="M2,9 L7,14 L16,4" Stroke="#4CAF50"
                                      StrokeThickness="2" StrokeLineJoin="Round"
                                      Visibility="Collapsed" Margin="1"/>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="#4CAF50"/>
                                <Setter TargetName="Box" Property="Background" Value="#1A2E1A"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#4CAF50"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Section header ── -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4CAF50"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,20,0,10"/>
        </Style>

        <!-- ── Field label ── -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#78909C"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#12121C" Padding="24,18,24,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚙" FontSize="20" Foreground="#4CAF50" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel>
                    <TextBlock Text="Settings" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Configure alerts, sound and API keys" FontSize="11" Foreground="#546E7A"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="1" Padding="24,0,16,0">
            <StackPanel Margin="0,0,8,24">

                <!-- POLLING -->
                <TextBlock Text="⏱  POLLING" Style="{StaticResource SectionHeader}"/>
                <Border Background="#12121C" CornerRadius="8" Padding="16,14" Margin="0,0,0,2">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="160"/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Check Interval" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="How often to fetch live prices" Foreground="#546E7A" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1" x:Name="IntervalCombo" Style="{StaticResource DarkComboBox}" VerticalAlignment="Center">
                            <ComboBoxItem>1 second</ComboBoxItem>
                            <ComboBoxItem>5 seconds</ComboBoxItem>
                            <ComboBoxItem>10 seconds</ComboBoxItem>
                            <ComboBoxItem>30 seconds</ComboBoxItem>
                        </ComboBox>
                    </Grid>
                </Border>

                <!-- SOUND -->
                <TextBlock Text="🔊  SOUND" Style="{StaticResource SectionHeader}"/>
                <Border Background="#12121C" CornerRadius="8" Padding="16,14" Margin="0,0,0,2">
                    <StackPanel>
                        <!-- Enable toggle -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Enable Alert Sound" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Play sound when alert triggers" Foreground="#546E7A" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="SoundCheck" Grid.Column="1" VerticalAlignment="Center"/>
                        </Grid>
                        <!-- Volume -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="160"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Volume" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Value, ElementName=VolumeSlider, StringFormat={}Level: {0:P0}}"
                                           Foreground="#546E7A" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Slider Grid.Column="1" x:Name="VolumeSlider" Minimum="0" Maximum="1"
                                    TickFrequency="0.1" IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center" Foreground="#4CAF50"/>
                        </Grid>
                        <!-- Sound file -->
                        <TextBlock Text="Sound File" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="44"/></Grid.ColumnDefinitions>
                            <TextBox x:Name="SoundFileBox" IsReadOnly="True"/>
                            <Button Grid.Column="1" Content="…" Margin="6,0,0,0" Height="36"
                                    Cursor="Hand" Click="BrowseSound_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="#2D2D3F" CornerRadius="6"
                                                BorderBrush="#3D3D5F" BorderThickness="1">
                                            <TextBlock Text="…" Foreground="White" FontSize="16"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#3D3D5F"/>
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4CAF50"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- WINDOW -->
                <TextBlock Text="🪟  WINDOW" Style="{StaticResource SectionHeader}"/>
                <Border Background="#12121C" CornerRadius="8" Padding="16,14" Margin="0,0,0,2">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Popup Always on Top" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Alert popup stays above all windows" Foreground="#546E7A" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="TopCheck" Grid.Column="1" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Auto-start with Windows" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Launch on Windows startup" Foreground="#546E7A" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="AutoStartCheck" Grid.Column="1" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- API KEYS -->
                <TextBlock Text="🔑  API KEYS" Style="{StaticResource SectionHeader}"/>
                <Border Background="#12121C" CornerRadius="8" Padding="16,14" Margin="0,0,0,2">
                    <StackPanel>
                        <TextBlock Text="Alpha Vantage Key" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,2"/>
                        <TextBlock Text="Optional — for USOIL fallback. Get free key at alphavantage.co" Foreground="#546E7A" FontSize="11" Margin="0,0,0,6"/>
                        <TextBox x:Name="OilKeyBox"/>
                    </StackPanel>
                </Border>

                <!-- Info tip -->
                <Border Background="#0A1F0A" CornerRadius="8" Padding="14,10" Margin="0,12,0,0"
                        BorderBrush="#1A3A1A" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💡" FontSize="14" VerticalAlignment="Top" Margin="0,1,8,0"/>
                        <TextBlock Foreground="#4CAF50" FontSize="11" TextWrapping="Wrap">
                            All prices are now FREE with no API key needed!
                            Crypto via Binance • Gold/Silver via Frankfurter.app • Oil via EIA.gov
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer buttons -->
        <Border Grid.Row="2" Background="#12121C" Padding="24,14">
            <Grid>
                <TextBlock Text="v1.6.7" Foreground="#2D2D4F" FontSize="11" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Width="100" Height="38" Margin="0,0,10,0"
                            Cursor="Hand" Click="Cancel_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#2D2D3F" CornerRadius="6"
                                        BorderBrush="#3D3D5F" BorderThickness="1">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#3D3D5F"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Foreground><SolidColorBrush Color="#B0BEC5"/></Button.Foreground>
                    </Button>
                    <Button Content="💾  Save Settings" Width="148" Height="38"
                            FontWeight="Bold" Cursor="Hand" Click="Save_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#4CAF50" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#43A047"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#388E3C"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Foreground><SolidColorBrush Color="White"/></Button.Foreground>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
