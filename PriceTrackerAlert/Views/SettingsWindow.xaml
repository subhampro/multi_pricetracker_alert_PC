<Window x:Class="PriceTrackerAlert.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Width="480" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#12121C"
        Icon="/Assets/icon.ico">

    <Window.Resources>
        <!-- Slim scrollbar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="#1E1E2E" CornerRadius="3" Width="5">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#3D3D5F" CornerRadius="3" Margin="1"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#4CAF50"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox -->
        <Style x:Key="Combo" TargetType="ComboBox">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd" Background="#1E1E2E" BorderBrush="#2D2D4F"
                                    BorderThickness="1" CornerRadius="8"/>
                            <Grid Margin="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="32"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                  Margin="14,0,0,0" VerticalAlignment="Center"
                                                  IsHitTestVisible="False"/>
                                <ToggleButton Grid.ColumnSpan="2" Opacity="0"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                                <Path Grid.Column="1" Data="M0,0 L5,6 L10,0" Stroke="#546E7A"
                                      StrokeThickness="1.5" HorizontalAlignment="Center"
                                      VerticalAlignment="Center" IsHitTestVisible="False"/>
                            </Grid>
                            <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" Placement="Bottom">
                                <Border Background="#1E1E2E" BorderBrush="#2D2D4F" BorderThickness="1"
                                        CornerRadius="8" MinWidth="{TemplateBinding ActualWidth}">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="16" Opacity="0.5" ShadowDepth="4"/>
                                    </Border.Effect>
                                    <ScrollViewer>
                                        <ItemsPresenter Margin="0,4"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4CAF50"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="14,9"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}" CornerRadius="6" Margin="4,1">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#2D2D4F"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderBrush" Value="#2D2D4F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#4CAF50"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle CheckBox -->
        <Style TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Track" Width="42" Height="24" CornerRadius="12"
                                Background="#2D2D4F">
                            <Ellipse x:Name="Thumb" Width="18" Height="18" Fill="White"
                                     HorizontalAlignment="Left" Margin="3,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#4CAF50"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#0D0D1A" Padding="28,20">
            <StackPanel Orientation="Horizontal">
                <Border Width="36" Height="36" CornerRadius="10" Background="#1A3A1A" Margin="0,0,14,0">
                    <TextBlock Text="⚙" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Settings" FontSize="17" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Customize your alert preferences" FontSize="11" Foreground="#546E7A"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="28,20,22,0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,6,24" >

                <!-- POLLING -->
                <TextBlock Text="POLLING" Foreground="#546E7A" FontSize="10" FontWeight="Bold"
                           Margin="0,0,0,10"/>
                <Border Background="#0D0D1A" CornerRadius="10" Padding="18,14" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Check Interval" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="How often prices are fetched" Foreground="#546E7A" FontSize="11" Margin="0,3,0,0"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1" x:Name="IntervalCombo" Style="{StaticResource Combo}" VerticalAlignment="Center">
                            <ComboBoxItem>1 second</ComboBoxItem>
                            <ComboBoxItem>5 seconds</ComboBoxItem>
                            <ComboBoxItem>10 seconds</ComboBoxItem>
                            <ComboBoxItem>30 seconds</ComboBoxItem>
                        </ComboBox>
                    </Grid>
                </Border>

                <!-- SOUND -->
                <TextBlock Text="SOUND" Foreground="#546E7A" FontSize="10" FontWeight="Bold"
                           Margin="0,0,0,10"/>
                <Border Background="#0D0D1A" CornerRadius="10" Padding="18,14" Margin="0,0,0,16">
                    <StackPanel>
                        <!-- Enable -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Alert Sound" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Play sound when price alert triggers" Foreground="#546E7A" FontSize="11" Margin="0,3,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="SoundCheck" Grid.Column="1" VerticalAlignment="Center"/>
                        </Grid>
                        <!-- Volume -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Volume" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Foreground="#546E7A" FontSize="11" Margin="0,3,0,0"
                                           Text="{Binding Value, ElementName=VolumeSlider, StringFormat={}{0:P0}}"/>
                            </StackPanel>
                            <Slider Grid.Column="1" x:Name="VolumeSlider" Minimum="0" Maximum="1"
                                    TickFrequency="0.1" IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center" Foreground="#4CAF50"/>
                        </Grid>
                        <!-- Sound file -->
                        <TextBlock Text="Sound File" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                            <TextBox x:Name="SoundFileBox" IsReadOnly="True"/>
                            <Button Grid.Column="1" Margin="6,0,0,0" Height="38" Cursor="Hand" Click="BrowseSound_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="#1E1E2E" CornerRadius="8"
                                                BorderBrush="#2D2D4F" BorderThickness="1">
                                            <TextBlock Text="…" Foreground="#B0BEC5" FontSize="16"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4CAF50"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- BEHAVIOUR -->
                <TextBlock Text="BEHAVIOUR" Foreground="#546E7A" FontSize="10" FontWeight="Bold"
                           Margin="0,0,0,10"/>
                <Border Background="#0D0D1A" CornerRadius="10" Padding="18,14" Margin="0,0,0,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Popup Always on Top" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Alert window stays above all other windows" Foreground="#546E7A" FontSize="11" Margin="0,3,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="TopCheck" Grid.Column="1" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Auto-start with Windows" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Launch automatically on Windows startup" Foreground="#546E7A" FontSize="11" Margin="0,3,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="AutoStartCheck" Grid.Column="1" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- DATA SOURCES -->
                <TextBlock Text="DATA SOURCES" Foreground="#546E7A" FontSize="10" FontWeight="Bold"
                           Margin="0,0,0,10"/>
                <Border Background="#0D0D1A" CornerRadius="10" Padding="18,14">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Crypto (BTC/ETH/BNB/SOL/XRP)" Foreground="#B0BEC5" FontSize="12"/>
                            <Border Grid.Column="1" Background="#0A2A0A" CornerRadius="4" Padding="8,3">
                                <TextBlock Text="Binance  ✓ Free" Foreground="#4CAF50" FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Gold (XAUUSD) &amp; Silver (XAGUSD)" Foreground="#B0BEC5" FontSize="12"/>
                            <Border Grid.Column="1" Background="#0A2A0A" CornerRadius="4" Padding="8,3">
                                <TextBlock Text="OANDA / TVC  ✓ Free" Foreground="#4CAF50" FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Oil (USOIL / WTI Crude)" Foreground="#B0BEC5" FontSize="12"/>
                            <Border Grid.Column="1" Background="#0A2A0A" CornerRadius="4" Padding="8,3">
                                <TextBlock Text="FX / EIA  ✓ Free" Foreground="#4CAF50" FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#0D0D1A" Padding="28,16">
            <Grid>
                <TextBlock Text="v1.6.9" Foreground="#2D2D4F" FontSize="11" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Width="96" Height="38" Margin="0,0,10,0"
                            Cursor="Hand" Click="Cancel_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#1E1E2E" CornerRadius="8"
                                        BorderBrush="#2D2D4F" BorderThickness="1">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#2D2D4F"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Foreground><SolidColorBrush Color="#78909C"/></Button.Foreground>
                    </Button>
                    <Button Content="Save" Width="96" Height="38" FontWeight="Bold"
                            Cursor="Hand" Click="Save_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="#4CAF50" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#43A047"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#388E3C"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Foreground><SolidColorBrush Color="White"/></Button.Foreground>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
