<Window x:Class="PriceTrackerAlert.Views.AlertPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔔 Price Alert Triggered"
        Width="420" Height="300"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E2E">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="🔔 PRICE ALERT TRIGGERED"
                   FontSize="20" FontWeight="Bold" Foreground="#FF5252"
                   HorizontalAlignment="Center" Margin="0,0,0,16"/>

        <!-- Details -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="SymbolText"    FontSize="32" FontWeight="Bold" Foreground="White"
                       HorizontalAlignment="Center"/>
            <TextBlock x:Name="ConditionText" FontSize="16" Foreground="#B0BEC5"
                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
            <TextBlock x:Name="LivePriceText" FontSize="28" FontWeight="Bold" Foreground="#4CAF50"
                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
            <TextBlock x:Name="NoteText"      FontSize="13" Foreground="#78909C"
                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
            <Button x:Name="AckButton" Content="✔ Acknowledge"
                    Width="150" Height="40" Margin="0,0,12,0"
                    Background="#4CAF50" Foreground="White" FontSize="14" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="AckButton_Click"/>
            <Button x:Name="SnoozeButton" Content="⏰ Snooze 5 min"
                    Width="150" Height="40"
                    Background="#FF9800" Foreground="White" FontSize="14" FontWeight="Bold"
                    BorderThickness="0" Cursor="Hand" Click="SnoozeButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
