<UserControl x:Class="PriceTrackerAlert.Views.SymbolIconControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="26" Height="26">
    <Grid>
        <!-- Colored circle background (always visible as fallback) -->
        <Ellipse x:Name="BgCircle" Width="26" Height="26"/>
        <!-- Fallback letter when SVG not loaded -->
        <TextBlock x:Name="FallbackText" Foreground="White" FontSize="9" FontWeight="Bold"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <!-- SVG image clipped to circle -->
        <Image x:Name="SvgImage" Width="26" Height="26" Stretch="Uniform">
            <Image.Clip>
                <EllipseGeometry Center="13,13" RadiusX="13" RadiusY="13"/>
            </Image.Clip>
        </Image>
    </Grid>
</UserControl>
