<Window x:Class="PriceTrackerAlert.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:conv="clr-namespace:PriceTrackerAlert.Converters"
        xmlns:vm="clr-namespace:PriceTrackerAlert.ViewModels"
        xmlns:models="clr-namespace:PriceTrackerAlert.Models"
        Title="Price Tracker Alert" Height="640" Width="860"
        MinWidth="760" MinHeight="500"
        Background="#12121C"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing">

    <Window.Resources>
        <conv:BoolToColorConverter     x:Key="BoolToColor"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolConverter     x:Key="InvBool"/>
        <conv:ConditionIndexConverter  x:Key="ConditionIdx"/>

        <Style TargetType="Button" x:Key="IconBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#B0BEC5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <Style TargetType="TextBox" x:Key="InputBox">
            <Setter Property="Background" Value="#2D2D3F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox" x:Key="InputCombo">
            <Setter Property="Background" Value="#2D2D3F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="34"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Border Grid.Row="0" Background="#1A1A2E" Padding="16,10">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📈" FontSize="22" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Price Tracker Alert" FontSize="18" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <CheckBox Content="Test Mode" Foreground="#FF9800" FontSize="12"
                              IsChecked="{Binding TestMode}" Margin="0,0,16,0" VerticalAlignment="Center"/>
                    <Button Content="⚙ Settings" Style="{StaticResource IconBtn}"
                            Command="{Binding OpenSettingsCommand}" Foreground="#4CAF50"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Add Alert Form -->
        <Border Grid.Row="1" Background="#1E1E2E" Padding="16,12" Margin="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="110"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="Symbol" Foreground="#78909C" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox Style="{StaticResource InputCombo}"
                              Text="{Binding NewSymbol, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True">
                        <ComboBoxItem Content="BTCUSDT"/>
                        <ComboBoxItem Content="ETHUSDT"/>
                        <ComboBoxItem Content="BNBUSDT"/>
                        <ComboBoxItem Content="SOLUSDT"/>
                        <ComboBoxItem Content="XRPUSDT"/>
                        <ComboBoxItem Content="XAUUSD"/>
                        <ComboBoxItem Content="USOIL"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                    <TextBlock Text="Target Price" Foreground="#78909C" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource InputBox}"
                             Text="{Binding NewTarget, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,8,0">
                    <TextBlock Text="Condition" Foreground="#78909C" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox Style="{StaticResource InputCombo}"
                              SelectedIndex="{Binding NewCondition, Converter={StaticResource ConditionIdx}}">
                        <ComboBoxItem Content="▲ Above"/>
                        <ComboBoxItem Content="▼ Below"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,8,0">
                    <TextBlock Text="Note (optional)" Foreground="#78909C" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource InputBox}"
                             Text="{Binding NewNote, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <Button Grid.Column="4" Content="＋ Add Alert"
                        Background="#4CAF50" Foreground="White" FontWeight="Bold"
                        BorderThickness="0" Padding="16,0" Height="34"
                        VerticalAlignment="Bottom" Cursor="Hand"
                        Command="{Binding AddAlertCommand}"/>
            </Grid>
        </Border>

        <!-- Alert List -->
        <ListView Grid.Row="2" x:Name="AlertList"
                  ItemsSource="{Binding Alerts}"
                  Background="#12121C" BorderThickness="0"
                  Foreground="White" Margin="0,2,0,0">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Symbol"      Width="90"
                                    DisplayMemberBinding="{Binding Symbol}"/>
                    <GridViewColumn Header="Condition"   Width="90"
                                    DisplayMemberBinding="{Binding Condition}"/>
                    <GridViewColumn Header="Target"      Width="110">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding TargetPrice, StringFormat={}{0:N2}}"
                                           Foreground="#FFD54F"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Live Price"  Width="110">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding LivePrice}" Foreground="#4CAF50"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Status"      Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StatusText}"
                                           Foreground="{Binding IsActive, Converter={StaticResource BoolToColor}}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Note"        Width="140"
                                    DisplayMemberBinding="{Binding Note}"/>
                    <GridViewColumn Header="Actions"     Width="180">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Tag="{Binding}"
                                            Click="ToggleBtn_Click"
                                            ToolTip="Enable / Disable">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource IconBtn}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Content" Value="⏸"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                        <Setter Property="Content" Value="▶"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="🔄" Style="{StaticResource IconBtn}"
                                            Tag="{Binding}" Click="ResetBtn_Click"
                                            ToolTip="Reset trigger"/>
                                    <Button Content="🗑" Style="{StaticResource IconBtn}"
                                            Foreground="#EF5350"
                                            Tag="{Binding}" Click="DeleteBtn_Click"
                                            ToolTip="Delete alert"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Status bar -->
        <Border Grid.Row="3" Background="#1A1A2E" Padding="16,6">
            <TextBlock Text="{Binding StatusText}" Foreground="#546E7A" FontSize="12"/>
        </Border>
    </Grid>
</Window>
